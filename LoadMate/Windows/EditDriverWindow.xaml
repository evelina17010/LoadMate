<Window x:Class="LoadMate.Windows.EditDriverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
          Title="Редактирование водителя" 
        Height="620" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">
    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Border Style="{StaticResource Card}" Padding="25" Margin="20">
            <StackPanel>
                <TextBlock Text="Редактирование водителя" FontSize="22" FontWeight="SemiBold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="ФИО" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtFullName" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Email" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Телефон" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <TextBox x:Name="txtPhone" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Логин (неизменяемо)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource InputField}" Height="40" IsEnabled="False" Opacity="0.6"/>

                <TextBlock Text="Новый пароль (если нужно сменить)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource PasswordField}" Height="40"/>

                <TextBlock Text="Номер лицензии" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <TextBox x:Name="txtLicenseNumber" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Стаж (лет)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <TextBox x:Name="txtExperience" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Статус водителя" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <ComboBox x:Name="cmbStatus" Style="{StaticResource ComboBoxField}" Height="40" SelectedValuePath="DriverStatus_id">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="120" Height="40" Click="Save_Click"/>
                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="120" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
