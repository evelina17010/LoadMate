<Window x:Class="LoadMate.Windows.EditCargoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
      Title="Редактирование груза" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">

    <Border Style="{StaticResource Card}" Padding="25" Margin="20">
        <StackPanel>
            <TextBlock Text="Редактирование груза" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock Text="Клиент" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="cmbClient" Style="{StaticResource ComboBoxField}" Height="40"/>

            <TextBlock Text="Тип груза" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="cmbCargoType" Style="{StaticResource ComboBoxField}" Height="40"/>

            <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtDescription" Style="{StaticResource InputField}" Height="80" TextWrapping="Wrap"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Вес (кг)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtWeight" Style="{StaticResource InputField}" Height="40"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Объем (м³)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtVolume" Style="{StaticResource InputField}" Height="40"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="chkFragile" Content="Хрупкий груз" Margin="0,10,0,5"/>
            <CheckBox x:Name="chkDangerous" Content="Опасный груз" Margin="0,5,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="100" Height="40" Click="Save_Click"/>
                <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="100" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
