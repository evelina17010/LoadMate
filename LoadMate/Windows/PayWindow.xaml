<Window x:Class="LoadMate.Windows.PayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
      Title="Оплата заказа" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">

    <Border Style="{StaticResource Card}" Padding="25" Margin="20">
        <StackPanel>
            <TextBlock Text="Оплата заказа" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <Border Style="{StaticResource Card}" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtOrderNumber" Margin="10,5,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма к оплате:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAmount" Margin="10,5,0,5" Foreground="{StaticResource PrimaryColor}" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Статус:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtStatus" Margin="10,5,0,5"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Способ оплаты" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource ComboBoxField}" Height="40" Margin="0,5,0,20">
                <ComboBoxItem Content="Банковская карта" IsSelected="True"/>
                <ComboBoxItem Content="СБП"/>
                <ComboBoxItem Content="Электронный кошелек"/>
                <ComboBoxItem Content="Наличные при получении"/>
            </ComboBox>

            <TextBlock Text="Номер карты" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtCardNumber" Style="{StaticResource InputField}" Height="40" Margin="0,5,0,15" />

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Срок действия" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtExpiry" Style="{StaticResource InputField}" Height="40" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="CVV/CVC" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="txtCvv" Style="{StaticResource PasswordField}" Height="40"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="chkSaveCard" Content="Сохранить карту для будущих платежей" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Оплатить" Style="{StaticResource ActionButton}" Width="120" Height="40" Click="Pay_Click"/>
                <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="120" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>