<Window x:Class="LoadMate.Windows.AssignDriverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
   Title="Назначение водителя" 
        Height="800" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundLight}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border CornerRadius="20" Background="White" Padding="25" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Назначение водителя на заказ" FontSize="22" FontWeight="SemiBold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <Border Grid.Row="1" CornerRadius="15" Padding="20" Margin="0,0,0,25" Background="#F0F4F8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Детали заказа" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkColor}"/>
                        </StackPanel>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Номер заказа" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtOrderNumber" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Клиент" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtClient" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Груз" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtCargo" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Маршрут" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtRoute" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Выберите свободного водителя" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="DriversGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" 
                              AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True"
                              SelectionChanged="DriversGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding DriverName}" Width="*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Лицензия" Binding="{Binding License_number}" Width="110"/>
                            <DataGridTextColumn Header="Опыт (лет)" Binding="{Binding Experience_years}" Width="90"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding DriverStatus}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                    <Button Content="Назначить" Style="{StaticResource ActionButton}" Width="150" Height="45" Click="Assign_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" 
                            Width="150" Height="45" Margin="20,0,0,0" Click="Cancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</Window>