<Window x:Class="LoadMate.Windows.AssignTruckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
     Title="Назначение транспорта" 
        Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundLight}">
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource Card}" Padding="25" Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Назначение транспорта на заказ" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Информация о заказе" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" FontWeight="Bold" Margin="0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtOrderNumber" Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Вес груза:" FontWeight="Bold" Margin="0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtWeight" Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Объем груза:" FontWeight="Bold" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtVolume" Margin="10,5,0,5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <CheckBox x:Name="chkOnlyAvailable" Content="Только доступный транспорт" Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Мин. грузоподъемность (кг):" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtMinCapacity" Style="{StaticResource InputField}" Width="120" Height="35" Margin="10,0,0,0"/>
                        <Button Content="Применить фильтр" Style="{StaticResource ActionButton}" Height="35" Click="ApplyFilter_Click" Margin="10,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Доступные транспортные средства" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <DataGrid x:Name="TrucksGrid" Grid.Row="2" Style="{StaticResource DataGridStyle}" 
                          AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="TrucksGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*"/>
                            <DataGridTextColumn Header="Рег. номер" Binding="{Binding Registration_number}" Width="120"/>
                            <DataGridTextColumn Header="Грузоподъемность (кг)" Binding="{Binding Capacity_kg}" Width="120"/>
                            <DataGridTextColumn Header="Объем (м³)" Binding="{Binding Capacity_m3}" Width="100"/>
                            <DataGridTextColumn Header="Водитель" Binding="{Binding Driver.User.Full_name}" Width="150"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding TruckStatus.Name}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Назначить" Style="{StaticResource ActionButton}" Width="120" Height="40" Click="Assign_Click"/>
                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="120" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</Window>