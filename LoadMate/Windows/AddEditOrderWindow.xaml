<Window x:Class="LoadMate.Windows.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
Title="Данные заказа" Height="850" Width="600" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="{StaticResource BackgroundLight}">

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Border Style="{StaticResource Card}" Padding="30" Margin="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtTitle" Text="Новый заказ" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Номер заказа" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox x:Name="tbOrderNumber" Style="{StaticResource InputField}" Height="45" IsEnabled="False" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Клиент" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbClient" Style="{StaticResource ComboBoxField}" Height="45" SelectedValuePath="User_id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Full_name}" Padding="5"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <TextBlock Text="Описание груза" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <TextBox x:Name="tbCargoDesc" Style="{StaticResource InputField}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Padding="10"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="3" Columns="2" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Вес (кг)" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox x:Name="tbWeight" Style="{StaticResource InputField}" Height="45" TextChanged="UpdateCost_Event"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Объем (м³)" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                            <TextBox x:Name="tbVolume" Style="{StaticResource InputField}" Height="45" TextChanged="UpdateCost_Event"/>
                        </StackPanel>
                    </UniformGrid>

                    <GroupBox Grid.Row="4" Header="Пункт отправления" Margin="0,0,0,20" Padding="10" Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold">
                        <StackPanel>
                            <ComboBox x:Name="cmbStartCity" Style="{StaticResource ComboBoxField}" Height="45" Margin="0,5" 
                                      SelectedValuePath="City_id" SelectionChanged="City_SelectionChanged" Tag="Start">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ComboBox x:Name="cmbStartStreet" Style="{StaticResource ComboBoxField}" Height="45" Margin="0,5" SelectedValuePath="Street_id">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox x:Name="txtStartHouse" Style="{StaticResource InputField}" Height="45" Margin="0,5" Tag="Номер дома"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="5" Header="Пункт назначения" Margin="0,0,0,20" Padding="10" Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold">
                        <StackPanel>
                            <ComboBox x:Name="cmbEndCity" Style="{StaticResource ComboBoxField}" Height="45" Margin="0,5" 
                                      SelectedValuePath="City_id" SelectionChanged="City_SelectionChanged" Tag="End">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ComboBox x:Name="cmbEndStreet" Style="{StaticResource ComboBoxField}" Height="45" Margin="0,5" SelectedValuePath="Street_id">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox x:Name="txtEndHouse" Style="{StaticResource InputField}" Height="45" Margin="0,5" Tag="Номер дома"/>
                        </StackPanel>
                    </GroupBox>

                    <StackPanel Grid.Row="6" Margin="0,10,0,0">
                        <TextBlock Text="Тариф" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbTariff" Style="{StaticResource ComboBoxField}" Height="45" Margin="0,0,0,15"
                                  SelectedValuePath="Tariff_id" SelectionChanged="UpdateCost_Event">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Background="#F8FAFC" CornerRadius="10" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBlock x:Name="tbPriceDisplay" Text="Итоговая стоимость: 0.00 руб." FontSize="20" FontWeight="Bold" 
                                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                    <Button Content="Отмена" Width="140" Height="45" Style="{StaticResource ActionButton}" 
                            Background="#94A3B8" Click="Cancel_Click" Margin="0,0,15,0"/>
                    <Button Content="Сохранить заказ" Width="180" Height="45" Style="{StaticResource ActionButton}" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</Window>