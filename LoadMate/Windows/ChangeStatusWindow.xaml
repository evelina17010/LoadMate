<Window x:Class="LoadMate.Windows.ChangeStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
       Title="Изменение статуса" 
        Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource Card}" Padding="30" Margin="20,20,20,14">
            <StackPanel>
                <TextBlock Text="Изменение статуса заказа" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Выберите новый статус" Style="{StaticResource FieldLabel}" FontSize="14"/>
                <ComboBox x:Name="cmbStatus" Style="{StaticResource ComboBoxField}" Height="45" Margin="0,5,0,25"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="120" Height="40" Click="Save_Click"/>
                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="120" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>