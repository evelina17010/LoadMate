<Window x:Class="LoadMate.Windows.EditTariffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
        Title="Редактирование тарифа" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource Card}" Padding="25" Margin="20">
            <StackPanel>
                <TextBlock Text="Редактирование тарифа" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Название" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtName" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtDescription" Style="{StaticResource InputField}" Height="60" TextWrapping="Wrap"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Цена за км (руб.)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtCostPerKm" Style="{StaticResource InputField}" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Цена за кг (руб.)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtCostPerKg" Style="{StaticResource InputField}" Height="40"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Цена за м³ (руб.)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtCostPerM3" Style="{StaticResource InputField}" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Доп. сбор (руб.)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtAdditionalCost" Style="{StaticResource InputField}" Height="40"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Минимальная цена (руб.)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtMinPrice" Style="{StaticResource InputField}" Height="40"/>

                <CheckBox x:Name="chkIsActive" Content="Активен" Margin="0,15,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="100" Height="40" Click="Save_Click"/>
                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="100" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>