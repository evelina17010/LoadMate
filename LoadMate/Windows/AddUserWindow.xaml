<Window x:Class="LoadMate.Windows.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
      Title="Добавление пользователя" 
        Height="750" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource Card}" Padding="25" Margin="20">
            <StackPanel>
                <TextBlock Text="Добавление пользователя" FontSize="22" FontWeight="SemiBold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button Click="SelectPhoto_Click" Cursor="Hand" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="border" Width="130" Height="130" 
                           BorderBrush="{StaticResource PrimaryColor}" 
                           BorderThickness="2" CornerRadius="65" Background="White">
                                    <Grid>
                                        <StackPanel x:Name="placeholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="40" 
                                          Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Выбрать" FontSize="11" Padding="0 20 0 0"
                                          Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Border CornerRadius="65" Background="Transparent">
                                            <Border.OpacityMask>
                                                <VisualBrush>
                                                    <VisualBrush.Visual>
                                                        <Border Width="130" Height="130" CornerRadius="65" Background="Black"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Border.OpacityMask>
                                            <Image x:Name="imgPreview" Stretch="UniformToFill" 
                                      Source="{Binding ElementName=imgAvatar, Path=Source}"/>
                                        </Border>

                                        <Border x:Name="hoverLayer" CornerRadius="65" Background="#22000000" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="hoverLayer" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextSecondary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Image x:Name="imgAvatar" Visibility="Collapsed"/>

                <TextBlock Text="ФИО" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtFullName" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Телефон" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtPhone" Style="{StaticResource InputField}" Height="40" ToolTip="Формат: +7XXXXXXXXXX"/>

                <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource PasswordField}" Height="40"/>

                <TextBlock Text="Пол" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="cmbGender" Style="{StaticResource ComboBoxField}" Height="40"
                          HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Margin="0,0,0,10">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Роль" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="cmbRole" Style="{StaticResource ComboBoxField}" Height="40"
                          HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Margin="0,0,0,20">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="110" Height="40" Click="Save_Click"/>
                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" 
                            Width="110" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>