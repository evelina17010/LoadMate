<Window x:Class="LoadMate.Windows.EditTruckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
       Title="Редактирование транспорта" 
        Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Style="{StaticResource Card}" Padding="25" Margin="20">
            <StackPanel>
                <TextBlock Text="Редактирование транспорта" FontSize="22" FontWeight="SemiBold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Модель" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtModel" Style="{StaticResource InputField}" Height="40"/>

                <TextBlock Text="Регистрационный номер" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtRegNumber" Style="{StaticResource InputField}" Height="40"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Грузоподъемность (кг)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtCapacityKg" Style="{StaticResource InputField}" Height="40"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Объем (м³)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtCapacityM3" Style="{StaticResource InputField}" Height="40"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Статус" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <ComboBox x:Name="cmbStatus" Style="{StaticResource ComboBoxField}" Height="40" SelectedValuePath="TruckStatus_id">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Водитель" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                <ComboBox x:Name="cmbDriver" Style="{StaticResource ComboBoxField}" Height="40" SelectedValuePath="Driver_id">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DriverName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="120" Height="40" Click="Save_Click"/>
                    <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="120" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>