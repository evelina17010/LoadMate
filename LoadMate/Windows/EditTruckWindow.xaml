<Window x:Class="LoadMate.Windows.EditTruckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Windows"
        mc:Ignorable="d"
        Title="Редактирование транспорта" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLight}">

    <Border Style="{StaticResource Card}" Padding="25" Margin="20">
        <StackPanel>
            <TextBlock Text="Редактирование транспорта" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock Text="Модель" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtModel" Style="{StaticResource InputField}" Height="40"/>

            <TextBlock Text="Регистрационный номер" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtRegNumber" Style="{StaticResource InputField}" Height="40"/>

            <TextBlock Text="Грузоподъемность (кг)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtCapacityKg" Style="{StaticResource InputField}" Height="40"/>

            <TextBlock Text="Объем (м³)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtCapacityM3" Style="{StaticResource InputField}" Height="40"/>

            <TextBlock Text="Габариты (ДхШхВ)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtDimensions" Style="{StaticResource InputField}" Height="40" />

            <TextBlock Text="Год выпуска" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtYear" Style="{StaticResource InputField}" Height="40"/>

            <TextBlock Text="Расход топлива (л/100км)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtFuelConsumption" Style="{StaticResource InputField}" Height="40"/>

            <TextBlock Text="Статус" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="cmbStatus" Style="{StaticResource ComboBoxField}" Height="40"/>

            <TextBlock Text="Водитель" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="cmbDriver" Style="{StaticResource ComboBoxField}" Height="40"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                <Button Content="Сохранить" Style="{StaticResource ActionButton}" Width="100" Height="40" Click="Save_Click"/>
                <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" Width="100" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>