<Page x:Class="LoadMate.Pages.AdminUsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
     Title="Управление пользователями" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Добавить" Style="{StaticResource ActionButton}" Click="AddUser_Click" Width="120" Height="40"/>
            <Button Content="Изменить" Style="{StaticResource ActionButton}" Click="EditUser_Click" Width="120" Height="40" Margin="10,0,0,0"/>
            <Button Content="Блокировать" Style="{StaticResource DangerButton}" Click="BlockUser_Click" Width="120" Height="40" Margin="10,0,0,0"/>
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="120" Height="40" Margin="10,0,0,0"/>

            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="30,0,5,0" FontWeight="Bold"/>
            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" 
                     TextChanged="Search_TextChanged" />

            <TextBlock Text="Роль:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>
            <ComboBox x:Name="cmbRoleFilter" 
          Style="{StaticResource ComboBoxField}"  
          Width="180" Height="40"  
          SelectionChanged="RoleFilter_Changed">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <DataGrid x:Name="UsersGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" 
                  AutoGenerateColumns="False" SelectionMode="Single" 
                  SelectionChanged="UsersGrid_SelectionChanged"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding User_id}" Width="60"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding Full_name}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="130"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding UserStatus.Name}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>