<Page x:Class="LoadMate.Pages.AdminUsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
    Title="Управление пользователями" 
      Height="768" Width="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Добавить" Style="{StaticResource ActionButton}" Click="AddUser_Click" Width="100" Height="40"/>
            <Button Content="Редактировать" Style="{StaticResource ActionButton}" Click="EditUser_Click" Width="100" Height="40" Margin="10,0,0,0"/>
            <Button Content="Заблокировать" Style="{StaticResource DangerButton}" Click="BlockUser_Click" Width="100" Height="40" Margin="10,0,0,0"/>
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40" Margin="10,0,0,0"/>

            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" Margin="20,0,0,0" TextChanged="Search_TextChanged"/>

            <ComboBox x:Name="cmbRoleFilter" Style="{StaticResource ComboBoxField}" Width="150" Height="40" Margin="10,0,0,0" SelectionChanged="RoleFilter_Changed">
                <ComboBoxItem Content="Все роли"/>
                <ComboBoxItem Content="Администратор"/>
                <ComboBoxItem Content="Клиент"/>
                <ComboBoxItem Content="Водитель"/>
                <ComboBoxItem Content="Диспетчер"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="UsersGrid" Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="UsersGrid_SelectionChanged"
                      MinWidth="1000">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding User_id}" Width="50"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding Full_name}" Width="180"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding UserStatus.Name}" Width="100"/>
                    <DataGridTextColumn Header="Дата регистрации" Binding="{Binding Created_at, StringFormat=dd.MM.yyyy}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>