<Window x:Class="LoadMate.Pages.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Pages"
        mc:Ignorable="d"
       Title="Уведомление" Height="220" Width="420" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True">

    <Border Background="White" CornerRadius="20" BorderThickness="1" BorderBrush="#EEEEEE">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.15" ShadowDepth="5"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Text="Уведомление" Grid.Row="0" 
                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock x:Name="txtMessage" Grid.Row="1" Text="Текст сообщения здесь..." 
                       FontSize="15" Foreground="#555555" TextWrapping="Wrap" 
                       TextAlignment="Center" VerticalAlignment="Center" LineHeight="20"/>

            <Button Grid.Row="2" Content="Принять" Width="150" Height="45"
                    Style="{StaticResource ActionButton}" 
                    Cursor="Hand" Click="Ok_Click" IsDefault="True"/>
        </Grid>
    </Border>
</Window>