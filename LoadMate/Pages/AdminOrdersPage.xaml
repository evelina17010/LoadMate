<Page x:Class="LoadMate.Pages.AdminOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
       Title="Управление заказами" 
         d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Удалить" Style="{StaticResource DangerButton}" Click="DeleteOrder_Click" Width="100" Height="40"/>
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40" Margin="10,0,0,0"/>

            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" Margin="20,0,0,0" 
                     TextChanged="Search_TextChanged" />

            <ComboBox x:Name="cmbStatusFilter" Style="{StaticResource ComboBoxField}" Width="150" Height="40" Margin="10,0,0,0" 
                      SelectionChanged="StatusFilter_Changed">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Новый"/>
                <ComboBoxItem Content="Подтвержден"/>
                <ComboBoxItem Content="Назначен водитель"/>
                <ComboBoxItem Content="Загрузка"/>
                <ComboBoxItem Content="В пути"/>
                <ComboBoxItem Content="Доставлен"/>
                <ComboBoxItem Content="Завершен"/>
                <ComboBoxItem Content="Отменен"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="OrdersGrid" Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="OrdersGrid_SelectionChanged" MinWidth="1200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Order_id}" Width="50"/>
                    <DataGridTextColumn Header="№ заказа" Binding="{Binding Order_number}" Width="120"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="150"/>
                    <DataGridTextColumn Header="Груз" Binding="{Binding CargoDescription}" Width="150"/>
                    <DataGridTextColumn Header="Откуда" Binding="{Binding RouteFrom}" Width="180"/>
                    <DataGridTextColumn Header="Куда" Binding="{Binding RouteTo}" Width="180"/>
                    <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="120"/>
                    <DataGridTextColumn Header="Транспорт" Binding="{Binding TruckModel}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding Price, StringFormat={}{0:N2} руб.}" Width="100"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Order_date, StringFormat=dd.MM.yyyy}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>