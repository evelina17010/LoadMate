<Page x:Class="LoadMate.Pages.AdminCargoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
      Title="Управление грузами" 
        d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Добавить" Style="{StaticResource ActionButton}" Click="AddCargo_Click" Width="120" Height="40"/>
            <Button Content="Редактировать" Style="{StaticResource ActionButton}" Click="EditCargo_Click" Width="140" Height="40" Margin="10,0,0,0"/>
            <Button Content="Удалить" Style="{StaticResource DangerButton}" Click="DeleteCargo_Click" Width="100" Height="40" Margin="10,0,0,0"/>
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40" Margin="10,0,0,0"/>
            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="250" Height="40"  Margin="20 6 0 6" Tag="Поиск по клиенту или описанию..." TextChanged="Search_TextChanged"/>
        </StackPanel>

        <DataGrid x:Name="CargoGrid" Grid.Row="1"
                  Style="{StaticResource DataGridStyle}" 
                  AutoGenerateColumns="False" 
                  SelectionMode="Single" 
                  IsReadOnly="True"
                  SelectionChanged="CargoGrid_SelectionChanged"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Cargo_id}" Width="50"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="180"/>
                <DataGridTextColumn Header="Тип груза" Binding="{Binding CargoTypeName}" Width="120"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Вес (кг)" Binding="{Binding Weight_kg}" Width="80"/>
                <DataGridTextColumn Header="Объем (м³)" Binding="{Binding Volume_m3}" Width="80"/>
                <DataGridTextColumn Header="Хрупкий" Binding="{Binding IsFragileText}" Width="80"/>
                <DataGridTextColumn Header="Опасный" Binding="{Binding IsDangerousText}" Width="80"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Created_at, StringFormat=dd.MM.yyyy}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>