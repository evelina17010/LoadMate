<Page x:Class="LoadMate.Pages.ClientPaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
      Loaded="Page_Loaded"
   Title="Мои платежи" 
           d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40"/>
            <Button Content="Оплатить" Style="{StaticResource ActionButton}" Click="Pay_Click" Width="100" Height="40" Margin="10,0,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="PaymentsGrid" Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="PaymentsGrid_SelectionChanged" MinWidth="800">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="100"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N2} руб.}" Width="120"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="120"/>
                    <DataGridTextColumn Header="Дата платежа" Binding="{Binding Transaction_date, StringFormat=dd.MM.yyyy}" Width="120"/>
                    <DataGridTextColumn Header="Способ оплаты" Binding="{Binding Payment_method}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>