<Page x:Class="LoadMate.Pages.AdminStatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
  Title="Статистика и аналитика" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <TextBlock Text="Аналитика системы" FontSize="26" FontWeight="Bold"/>

                <Button Content="Обновить" 
                        Click="Refresh_Click" 
                        Margin="30,0,0,0" 
                        Style="{StaticResource ActionButton}" 
                        Width="140" Height="40"/>

                <Button Content="Экспорт отчета" 
                        Click="ExportReport_Click" 
                        Margin="10,0,0,0" 
                        Width="140" Height="40"
                        Background="#2E7D32" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                <Border Margin="5" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Общая выручка" Foreground="#757575" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtTotalRevenue" Text="0.00 руб." FontSize="22" FontWeight="Bold" Foreground="#2E7D32"/>
                    </StackPanel>
                </Border>

                <Border Margin="5" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Всего заказов" Foreground="#757575" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtTotalOrders" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}"/>
                    </StackPanel>
                </Border>

                <Border Margin="5" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Активные машины" Foreground="#757575" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtActiveTrucks" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F57C00"/>
                    </StackPanel>
                </Border>

                <Border Margin="5" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Средний чек" Foreground="#757575" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtAverageCheck" Text="0.00 руб." FontSize="22" FontWeight="Bold" Foreground="#455A64"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="5" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#F9F9F9" Padding="15" CornerRadius="8,8,0,0" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                            <TextBlock Text="Эффективность тарифов" FontWeight="Bold" FontSize="16"/>
                        </Border>

                        <DataGrid x:Name="TariffStatsGrid" Grid.Row="1" Margin="10"
                                  AutoGenerateColumns="False" IsReadOnly="True" 
                                  Style="{StaticResource DataGridStyle}"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Название тарифа" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Заказов" Binding="{Binding UsageCount}" Width="*"/>
                                <DataGridTextColumn Header="Выручка" Binding="{Binding TotalRevenue, StringFormat={}{0:N2} руб.}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Margin="5" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#F9F9F9" Padding="15" CornerRadius="8,8,0,0" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                            <TextBlock Text="Статусы заказов" FontWeight="Bold" FontSize="16"/>
                        </Border>

                        <ItemsControl x:Name="OrderStatusList" Grid.Row="1" Margin="15">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,10">
                                        <Grid>
                                            <TextBlock Text="{Binding StatusName}" HorizontalAlignment="Left" FontSize="14"/>
                                            <TextBlock Text="{Binding Count}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" FontSize="14"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>