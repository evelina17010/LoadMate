<Page x:Class="LoadMate.Pages.DispatcherTrucksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
     Title="Транспорт" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40"/>
            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" Margin="20,0,0,0" 
                     TextChanged="Search_TextChanged" />

            <ComboBox x:Name="cmbStatusFilter" Style="{StaticResource ComboBoxField}" Width="150" Height="40" Margin="10,0,0,0" 
                      SelectionChanged="StatusFilter_Changed">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Исправен"/>
                <ComboBoxItem Content="На ремонте"/>
                <ComboBoxItem Content="На маршруте"/>
                <ComboBoxItem Content="На техобслуживании"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="TrucksGrid" Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" MinWidth="900">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="150"/>
                    <DataGridTextColumn Header="Рег. номер" Binding="{Binding Registration_number}" Width="120"/>
                    <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="150"/>
                    <DataGridTextColumn Header="Грузоподъемность (кг)" Binding="{Binding Capacity_kg}" Width="120"/>
                    <DataGridTextColumn Header="Объем (м³)" Binding="{Binding Capacity_m3}" Width="80"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>