<Page x:Class="LoadMate.Pages.DispatcherTrucksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
    Title="Транспорт" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40"/>

            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>
            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" Margin="0,6,0,6" TextChanged="Search_TextChanged"/>

            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>
            <ComboBox x:Name="cmbStatusFilter" 
                      Style="{StaticResource ComboBoxField}"  
                      Width="180" Height="40"  
                      SelectionChanged="StatusFilter_Changed"
                      SelectedValuePath="TruckStatus_id">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="TrucksGrid" 
                      Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" 
                      MinWidth="900"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="150"/>
                    <DataGridTextColumn Header="Рег. номер" Binding="{Binding Registration_number}" Width="120"/>
                    <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="150"/>
                    <DataGridTextColumn Header="Грузоподъемность (кг)" Binding="{Binding Capacity_kg}" Width="120"/>
                    <DataGridTextColumn Header="Объем (м³)" Binding="{Binding Capacity_m3}" Width="80"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>