<Page x:Class="LoadMate.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
      Title="Личный кабинет клиента" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BackgroundWhite}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LoadMate" FontSize="26" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}" Margin="0,40,0,30" 
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>

                <Border Grid.Row="1" Background="{StaticResource BackgroundLight}" CornerRadius="12" Margin="20,0,20,30" Padding="10,15">
                    <StackPanel>
                        <Grid HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Ellipse Width="45" Height="45" Fill="{StaticResource PrimaryColor}"/>
                            <TextBlock Text="К" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                        </Grid>
                        <TextBlock Text="{Binding FullName}" 
                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" 
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="5,0"/>
                        <TextBlock Text="Клиент" FontSize="11" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2">
                    <Button x:Name="btnCreateOrder" Content="📝 Создать заказ" Style="{StaticResource SidebarButton}" Click="CreateOrder_Click"/>
                    <Button x:Name="btnMyOrders" Content="📋 Мои заказы" Style="{StaticResource SidebarButton}" Click="MyOrders_Click"/>
                    <Button x:Name="btnMyCargo" Content="📦 Мои грузы" Style="{StaticResource SidebarButton}" Click="Cargo_Click"/>
                    <Button x:Name="btnPayments" Content="💳 История платежей" Style="{StaticResource SidebarButton}" Click="Payments_Click"/>
                    <Separator Margin="20,15" Background="{StaticResource BorderColor}" Height="1"/>
                </StackPanel>

                <Button Grid.Row="3" Content=" Выйти из системы" Style="{StaticResource SidebarButton}" Click="Logout_Click" 
                        Foreground="{StaticResource ErrorColor}" Margin="10,0,10,20"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Добро пожаловать в LoadMate!" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Frame x:Name="ClientFrame" NavigationUIVisibility="Hidden"/>

                    <StackPanel x:Name="WelcomeContent" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ClientFrame, Path=Content}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="📦" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Выберите действие в меню слева" FontSize="18" FontWeight="Medium" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>