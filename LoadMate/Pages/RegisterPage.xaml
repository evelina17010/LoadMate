<Page x:Class="LoadMate.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
   Title="Регистрация" 
        d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Button Content="← Назад" Style="{StaticResource OutlineButton}" 
                    Background="Transparent" Foreground="{StaticResource TextSecondary}"
                    HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Margin="40,30,0,0" FontSize="18" Click="Back_Click"/>

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                <Border Style="{StaticResource Card}" Padding="40">
                    <StackPanel>
                        <TextBlock Text="Регистрация" FontSize="32" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Создайте новый аккаунт" FontSize="16" 
                                   Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <TextBlock Text="ФИО" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtFullName" Style="{StaticResource InputField}" Height="45"/>

                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource InputField}" Height="45"/>

                        <TextBlock Text="Телефон" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtPhone" Style="{StaticResource InputField}" Height="45"/>

                        <TextBlock Text="Пол" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbGender" Style="{StaticResource ComboBoxField}" Height="45" Margin="0 0 0 15"
          HorizontalContentAlignment="Left" VerticalContentAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource InputField}" Height="45" />

                        <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="txtPassword" Style="{StaticResource PasswordField}" Height="45"/>

                        <TextBlock Text="Подтверждение пароля" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="txtConfirmPassword" Style="{StaticResource PasswordField}" Height="45"/>

                        <Button Content="Зарегистрироваться" Style="{StaticResource ActionButton}" Height="50" FontSize="16" Click="Register_Click" Margin="0,20,0,10"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                            <TextBlock Text="Уже есть аккаунт?" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                            <Button Content="Войти" Style="{StaticResource OutlineButton}" 
                                    Background="Transparent" Foreground="{StaticResource PrimaryColor}" 
                                    FontSize="14" Padding="5,0" Margin="5,0,0,0" Click="Login_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>