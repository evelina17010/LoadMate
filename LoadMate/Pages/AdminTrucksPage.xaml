<Page x:Class="LoadMate.Pages.AdminTrucksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
     Title="Управление транспортом" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Добавить" Style="{StaticResource ActionButton}" Click="AddTruck_Click" Width="100" Height="40"/>
            <Button Content="Редактировать" Style="{StaticResource ActionButton}" Click="EditTruck_Click" Width="130" Height="40" Margin="10,0,0,0"/>
            <Button Content="Удалить" Style="{StaticResource DangerButton}" Click="DeleteTruck_Click" Width="100" Height="40" Margin="10,0,0,0"/>
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40" Margin="10,0,0,0"/>

            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="30,0,5,0" FontWeight="Bold"/>
            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" Margin="0 6 0 6"
                     TextChanged="Search_TextChanged" />
        </StackPanel>

        <DataGrid x:Name="TrucksGrid" 
                  Grid.Row="1" 
                  Style="{StaticResource DataGridStyle}" 
                  AutoGenerateColumns="False" 
                  SelectionMode="Single" 
                  SelectionChanged="TrucksGrid_SelectionChanged"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Truck_id}" Width="50"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="150"/>
                <DataGridTextColumn Header="Рег. номер" Binding="{Binding Registration_number}" Width="120"/>
                <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="150"/>
                <DataGridTextColumn Header="Грузоподъемность (кг)" Binding="{Binding Capacity_kg}" Width="150"/>
                <DataGridTextColumn Header="Объем (м³)" Binding="{Binding Capacity_m3}" Width="100"/>
                <DataGridTextColumn Header="Габариты" Binding="{Binding Dimensions}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>