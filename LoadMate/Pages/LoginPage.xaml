<Page x:Class="LoadMate.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Вход" 
      Height="768" Width="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Button Content="← Назад" Style="{StaticResource OutlineButton}" 
                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="40,30,0,0" FontSize="18" Click="Back_Click"/>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="480">
            <Border Style="{StaticResource Card}" Padding="40">
                <StackPanel>
                    <TextBlock Text="Добро пожаловать" FontSize="32" FontWeight="SemiBold" 
                               Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Войдите в свой аккаунт" FontSize="16" 
                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtUsername" Style="{StaticResource InputField}" Height="45"/>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="txtPassword" Style="{StaticResource PasswordField}" Height="45"/>

                    <Button Content="Войти" Style="{StaticResource ActionButton}" Height="50" FontSize="16" Click="Login_Click" Margin="0,20,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="Нет аккаунта?" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                        <Button Content="Зарегистрироваться" Style="{StaticResource OutlineButton}" 
                                Background="Transparent" Foreground="{StaticResource PrimaryColor}" 
                                FontSize="14" Padding="5,0" Margin="5,0,0,0" Click="Register_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>