<Page x:Class="LoadMate.Pages.DispatcherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
     Title="Панель диспетчера" 
    d:DesignHeight="768" d:DesignWidth="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border Background="{StaticResource PrimaryColor}" 
                    CornerRadius="0,40,0,0" 
                    Margin="0,70,0,0" 
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="130"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,45,0,0">
                        <TextBlock Text="LoadMate" Foreground="White" FontSize="20" FontWeight="Bold" 
               HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FullName}" 
               Foreground="White" FontSize="12" 
               HorizontalAlignment="Center" Opacity="0.7" Margin="0,5,0,0"
               TextWrapping="Wrap" TextAlignment="Center"/>

                        <Separator Background="White" Opacity="0.3" Margin="40,20,40,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="20,20,20,0">
                        <Button x:Name="btnOrders" Content="Все заказы" Style="{StaticResource SidebarButton}" Click="Orders_Click"/>
                        <Button x:Name="btnCreateOrder" Content="Новый заказ" Style="{StaticResource SidebarButton}" Click="CreateOrder_Click"/>

                        <Border Height="1" Background="White" Opacity="0.1" Margin="25,10"/>

                        <Button x:Name="btnDrivers" Content="Водители" Style="{StaticResource SidebarButton}" Click="Drivers_Click"/>
                        <Button x:Name="btnTrucks" Content="Автопарк" Style="{StaticResource SidebarButton}" Click="Trucks_Click"/>
                        <Button x:Name="btnTariffs" Content="Тарифы" Style="{StaticResource SidebarButton}" Click="Tariffs_Click"/>
                    </StackPanel>

                    <Button Grid.Row="2" Content="Выход" Style="{StaticResource SidebarButton}" 
                            Click="Logout_Click" Margin="20,0,20,40"/>
                </Grid>
            </Border>

            <Border Width="90" Height="90" 
                    Background="White" 
                    CornerRadius="45" 
                    Padding="4"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Top" 
                    Margin="0,25,0,0"
                    Panel.ZIndex="2">
                <Border CornerRadius="45">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding UserPhoto}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Background="Transparent">
            <Frame x:Name="DispatcherFrame" NavigationUIVisibility="Hidden" Margin="20"/>
        </Grid>
    </Grid>
</Page>