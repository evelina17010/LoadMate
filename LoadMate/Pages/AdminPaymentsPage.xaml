<Page x:Class="LoadMate.Pages.AdminPaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
         d:DesignHeight="768" d:DesignWidth="1366"
      Title="Управление платежами" 
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40"/>

            <ComboBox x:Name="cmbStatusFilter" Style="{StaticResource ComboBoxField}" Width="150" Height="40" Margin="10,0,0,0" 
                      SelectionChanged="StatusFilter_Changed">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Ожидает оплаты"/>
                <ComboBoxItem Content="Оплачен"/>
                <ComboBoxItem Content="Отменен"/>
                <ComboBoxItem Content="Возврат"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="PaymentsGrid" Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" MinWidth="900">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID платежа" Binding="{Binding Payment_id}" Width="80"/>
                    <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="120"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="150"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N2} руб.}" Width="120"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="120"/>
                    <DataGridTextColumn Header="Способ оплаты" Binding="{Binding Payment_method}" Width="130"/>
                    <DataGridTextColumn Header="Дата транзакции" Binding="{Binding Transaction_date, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Дата оплаты" Binding="{Binding Paid_date, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>