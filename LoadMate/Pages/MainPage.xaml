<Page x:Class="LoadMate.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Главная" 
      Height="768" Width="1366"
      Background="{StaticResource BackgroundLight}">

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="600"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}">
                <Grid Margin="80,0,80,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Вход" Style="{StaticResource OutlineButton}" Click="Login_Click" Margin="0,0,20,0"/>
                        <TextBlock Text="|" FontSize="25" Foreground="White" VerticalAlignment="Center"/>
                        <Button Content="Регистрация" Style="{StaticResource OutlineButton}" Click="Register_Click" Margin="20,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="LoadMate" FontSize="96" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Умная логистика для вашего бизнеса" FontSize="28" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                        <TextBlock Text="Доставка грузов по всей России с гарантией качества" FontSize="18" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,40"/>
                        <Button Content="Начать работу" Style="{StaticResource ActionButton}" Background="White" Foreground="{StaticResource PrimaryColor}" Width="200" Height="50" FontSize="16" Click="StartWork_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Background="{StaticResource BackgroundWhite}" Margin="0,60,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="40">
                    <TextBlock Text="🚚" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Грузоперевозки" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                    <TextBlock Text="Доставка грузов любой сложности по всей России. От 1 кг до 20 тонн." FontSize="14" TextWrapping="Wrap" Width="280" TextAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="40">
                    <TextBlock Text="🏭" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Складское хранение" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                    <TextBlock Text="Современные складские комплексы с круглосуточной охраной." FontSize="14" TextWrapping="Wrap" Width="280" TextAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Margin="40">
                    <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Управление заказами" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                    <TextBlock Text="Онлайн-отслеживание грузов и автоматизированная система управления." FontSize="14" TextWrapping="Wrap" Width="280" TextAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource BackgroundLight}" Padding="80,60">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="О компании" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                        <TextBlock Text="LoadMate - современная логистическая платформа, объединяющая клиентов, водителей и диспетчеров в единой системе управления перевозками." FontSize="16" TextWrapping="Wrap" Margin="0,20,0,30" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="✓ Более 1000 успешных доставок" FontSize="14" Margin="0,5"/>
                        <TextBlock Text="✓ 24/7 поддержка клиентов" FontSize="14" Margin="0,5"/>
                        <TextBlock Text="✓ Онлайн-отслеживание грузов" FontSize="14" Margin="0,5"/>
                        <TextBlock Text="✓ Автоматизированное управление" FontSize="14" Margin="0,5"/>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="50,0,0,0">
                        <StackPanel Margin="30">
                            <TextBlock Text="Свяжитесь с нами" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                            <TextBlock Text="8 (800) 555-35-35" FontSize="18" Foreground="{StaticResource PrimaryColor}" Margin="0,5"/>
                            <TextBlock Text="info@loadmate.ru" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Text="г. Москва, ул. Логистов, д. 1" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,20"/>
                            <TextBlock Text="Режим работы:" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Пн-Пт: 9:00 - 20:00" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="Сб-Вс: 10:00 - 18:00" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource PrimaryGradient}" Padding="80,40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LoadMate" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Современная логистическая платформа" FontSize="12" Foreground="White" Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="О компании" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="О нас" FontSize="12" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Контакты" FontSize="12" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Вакансии" FontSize="12" Foreground="White" Margin="0,5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Услуги" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Грузоперевозки" FontSize="12" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Складское хранение" FontSize="12" Foreground="White" Margin="0,5"/>
                        <TextBlock Text="Таможенное оформление" FontSize="12" Foreground="White" Margin="0,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="{StaticResource PrimaryDarkColor}" Padding="20">
                <TextBlock Text="© 2024 LoadMate. Все права защищены." FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>