<Window x:Class="LoadMate.Pages.AssignTransportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoadMate.Pages"
        mc:Ignorable="d"
    Title="Назначение транспорта" 
        Height="825" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundLight}">
    <Border Style="{StaticResource Card}" Padding="25" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Назначение транспорта на заказ" FontSize="22" FontWeight="SemiBold" 
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,25" Background="#F0F4F8" CornerRadius="15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Детали заказа" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkColor}"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Номер заказа" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtOrderNumber" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Клиент" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtClient" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Требуемый вес" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtWeight" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Требуемый объем" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="txtVolume" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                    <CheckBox x:Name="chkSmartFilter" Content="Умный подбор (попутные и свободные)" IsChecked="True" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Button Content="Обновить список" Style="{StaticResource ActionButton}" Height="30" Click="ApplyFilter_Click" Width="150"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Подходящий транспорт" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <DataGrid x:Name="TrucksGrid" 
                          Grid.Row="2"
                          Style="{StaticResource DataGridStyle}" 
                          AutoGenerateColumns="False" 
                          SelectionMode="Single" 
                          IsReadOnly="True"
                          SelectionChanged="TrucksGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*"/>
                        <DataGridTextColumn Header="Гос. номер" Binding="{Binding Registration_number}" Width="100"/>
                        <DataGridTextColumn Header="Свободно (кг)" Binding="{Binding FreeWeight}" Width="110"/>
                        <DataGridTextColumn Header="Свободно (м³)" Binding="{Binding FreeVolume}" Width="100"/>
                        <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Назначить" Style="{StaticResource ActionButton}" Width="130" Height="40" Click="Assign_Click"/>
                <Button Content="Отмена" Style="{StaticResource ActionButton}" Background="{StaticResource TextSecondary}" 
                        Width="130" Height="40" Margin="15,0,0,0" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>