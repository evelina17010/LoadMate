<Page x:Class="LoadMate.Pages.DispatcherDriversPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LoadMate.Pages"
      mc:Ignorable="d" 
     Title="Водители" 
      Height="768" Width="1366"
      Background="{StaticResource BackgroundLight}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Обновить" Style="{StaticResource ActionButton}" Click="Refresh_Click" Width="100" Height="40"/>
            <TextBox x:Name="txtSearch" Style="{StaticResource InputField}" Width="200" Height="40" Margin="20,0,0,0" 
                     TextChanged="Search_TextChanged" />

            <ComboBox x:Name="cmbStatusFilter" Style="{StaticResource ComboBoxField}" Width="150" Height="40" Margin="10,0,0,0" 
                      SelectionChanged="StatusFilter_Changed">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Доступен"/>
                <ComboBoxItem Content="На маршруте"/>
                <ComboBoxItem Content="Не доступен"/>
                <ComboBoxItem Content="Отдых"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="DriversGrid" Style="{StaticResource DataGridStyle}" 
                      AutoGenerateColumns="False" MinWidth="800">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding DriverName}" Width="200"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Номер лицензии" Binding="{Binding License_number}" Width="120"/>
                    <DataGridTextColumn Header="Стаж (лет)" Binding="{Binding Experience_years}" Width="80"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Page>